{
    "rewrites": [
        {
            "source": "/api/fudo/(.*)",
            "destination": "https://integrations.fu.do/fudo/$1"
        },
        {
            "source": "/api/places/(.*)",
            "destination": "https://places.googleapis.com/$1"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}